# Dokploy writes Environment values into a .env file next to the compose file.
# Keep real secrets in Dokploy Environment, not in git.
# Web and API ports are exposed only inside Docker; Dokploy/Traefik should route
# domains to service ports 3000 and 8000 without publishing host ports.

NEXT_PUBLIC_SITE_URL=https://pixelaid.example.com
PIXELAID_PUBLIC_API_URL=https://api.pixelaid.example.com
CORS_ORIGINS=https://pixelaid.example.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

VOICE_AGENT_API_TOKEN=replace-with-long-random-shared-secret

OPENAI_API_KEY=replace-me
DEEPGRAM_API_KEY=replace-me

VOICE_LATENCY_PROFILE=fast
TTS_PROVIDER=gemini
GOOGLE_API_KEY=replace-me

# Required only when TTS_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
OPENROUTER_TTS_VOICE_NAME=Kore
